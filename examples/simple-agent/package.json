{
  "name": "simple-agent",
  "version": "1.0.0",
  "type": "module",
  "description": "一个简单的 Agent 系统示例，基于第 08 篇教程构建",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --out-dir dist",
    "dev": "tsup src/index.ts --format esm --watch",
    "example:basic": "tsx examples/basic-usage.ts",
    "example:repl": "tsx examples/repl.ts",
    "example:custom-tool": "tsx examples/custom-tool.ts",
    "example:multi-agent": "tsx examples/multi-agent.ts",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "keywords": [
    "agent",
    "llm",
    "openai",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "openai": "^4.28.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
